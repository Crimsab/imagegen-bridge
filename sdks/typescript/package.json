{
  "name": "imagegen-bridge",
  "version": "0.3.0",
  "description": "Typed Bun and Node SDK for Imagegen Bridge",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Crimsab/imagegen-bridge.git",
    "directory": "sdks/typescript"
  },
  "homepage": "https://github.com/Crimsab/imagegen-bridge#readme",
  "bugs": {
    "url": "https://github.com/Crimsab/imagegen-bridge/issues"
  },
  "keywords": [
    "image-generation",
    "codex",
    "openai",
    "sdk"
  ],
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "README.md"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "engines": {
    "node": ">=20",
    "bun": ">=1.2"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "bun test",
    "test:node": "node tests/node-smoke.mjs",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@types/bun": "1.3.14",
    "typescript": "7.0.2"
  }
}
